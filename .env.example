# AgentScope - Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For local development with Docker:
#   docker compose up -d          # starts PostgreSQL + Splunk
#   ./scripts/splunk-setup.sh     # configure HEC token
#   ./scripts/splunk-mcp-setup.sh # install MCP server

# PostgreSQL
POSTGRES_URL=postgresql://agentscope:agentscope@localhost:5432/agentscope

# App URLs
# Required for invite links sent through Resend.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Auth (Better Auth)
# Generate with: openssl rand -hex 32
AUTH_SECRET=
# Optional: Discord OAuth
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=
AUTH_REDIRECT_PROXY_URL=

# Email (Resend)
# Required when inviting organization members.
RESEND_API_KEY=
RESEND_FROM=AgentScope <onboarding@example.com>

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# LLM Providers
# Global fallback keys for built-in OpenAI / Anthropic / Gemini providers.
# The investigator (Splunk MCP) uses OPENAI_API_KEY by default.
# Individual agents can override the provider, model, base URL, and key
# from the Agents page in the UI (stored encrypted in Postgres).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Agent API Key Encryption
# AES-256-GCM key wrapping for per-agent provider keys.
# Must be 64 hex chars (32 bytes). Defaults to a derivation of AUTH_SECRET
# at runtime, so this is only required to rotate the key independently.
# Generate with: openssl rand -hex 32
AGENTSCOPE_SECRETS_KEY=

# Splunk - HTTP Event Collector (HEC)
# Events are forwarded to Splunk via HEC for indexing.
# Set SPLUNK_HEC_TOKEN to enable forwarding.
# The default `splunk/splunk:latest` image creates the HEC input with
# SSL enabled and a self-signed certificate, so this URL must be HTTPS.
# The HEC client accepts that self-signed cert in dev; mount a real CA
# cert and remove the bypass for production.
SPLUNK_HEC_URL=https://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=agentscope-hec-token-abc123

# Splunk - Management API
# Used by the tRPC router for direct SPL searches.
SPLUNK_SEARCH_URL=https://localhost:8089/services/search/jobs
SPLUNK_USER=admin
SPLUNK_PASSWORD=agentscope123

# Splunk - Anomaly Detection
# Runs SPL queries via the management API for anomaly detection.
SPLUNK_ANOMALY_URL=https://localhost:8089/services/search/jobs
SPLUNK_ANOMALY_USER=admin
SPLUNK_ANOMALY_PASSWORD=agentscope123

# Splunk - MCP Server
# The Splunk MCP Server provides AI-native search via the
# Model Context Protocol (stdio transport).
# Install: ./scripts/splunk-mcp-setup.sh
SPLUNK_URL=https://localhost:8089
SPLUNK_TOKEN=
SPLUNK_INDEX=main
SPLUNK_MCP_COMMAND=splunk-mcp-server
SPLUNK_MCP_ENABLED=true

# OpenTelemetry
# Set to enable distributed tracing via OTLP.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Workers
# Agent runs are queued by the web app and executed by apps/workers.
AGENTSCOPE_WORKER_ID=local-worker
AGENTSCOPE_WORKER_POLL_MS=5000
AGENTSCOPE_OPERATIONAL_ALERT_POLL_MS=60000
AGENTSCOPE_ALERT_COOLDOWN_MS=900000

# Worker → API bridge.
# The Next.js API uses this URL to proxy the worker's /healthz endpoint
# (which exposes the live Splunk MCP connection state). Must be reachable
# from the API process. In a non-localhost deployment (e.g. Next.js on one
# container, worker on another), set this to the worker's internal DNS or
# service URL — the default of http://localhost:9090 only works when the
# worker and API share a network namespace.
AGENTSCOPE_METRICS_PORT=9090
WORKER_METRICS_URL=http://localhost:9090

# Splunk MCP heartbeat cadence (ms). The worker pings the MCP server on
# this interval so the dashboard's "MCP-enabled" badge reflects a live
# connection rather than a stale config flag. Set to 0 to disable.
AGENTSCOPE_MCP_HEARTBEAT_MS=30000
