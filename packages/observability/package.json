{
  "name": "@agentscope/observability",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "pino": "^9.5.0",
    "prom-client": "^15.1.3"
  },
  "peerDependencies": {
    "@sentry/browser": "*",
    "@sentry/node": "*"
  },
  "peerDependenciesMeta": {
    "@sentry/browser": { "optional": true },
    "@sentry/node": { "optional": true }
  },
  "devDependencies": {
    "@agentscope/eslint-config": "workspace:*",
    "@agentscope/prettier-config": "workspace:*",
    "@agentscope/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.22.4",
    "typescript": "catalog:"
  },
  "prettier": "@agentscope/prettier-config"
}
