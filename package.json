{
  "name": "agentscope",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "check:env": "bash scripts/check-env-placeholders.sh",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @agentscope/auth generate",
    "db:generate": "turbo -F @agentscope/db generate",
    "db:migrate": "turbo -F @agentscope/db migrate",
    "db:studio": "turbo -F @agentscope/db studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @agentscope/nextjs...",
    "dev:worker": "turbo watch dev -F @agentscope/workers...",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "prepare": "husky",
    "test": "turbo run test && pnpm test:generators",
    "test:generators": "tsx --test turbo/generators/config.test.ts",
    "typecheck": "turbo run typecheck && pnpm typecheck:generators",
    "typecheck:generators": "tsc -p turbo/generators/tsconfig.json --noEmit",
    "ui-add": "turbo run ui-add"
  },
  "devDependencies": {
    "@agentscope/prettier-config": "workspace:*",
    "@turbo/gen": "^2.5.8",
    "dotenv-cli": "^10.0.0",
    "husky": "^9.1.7",
    "prettier": "catalog:",
    "puppeteer-core": "^23.11.1",
    "tsx": "^4.22.4",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@agentscope/prettier-config"
}
